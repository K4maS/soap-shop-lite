# Database
DATABASE_URL=postgresql://shopuser:shoppassword@postgres:5432/shopdb

# JWT
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=15m

# App
PORT=4000
FRONTEND_URL=http://localhost:3000
NODE_ENV=production

# SMS (SMS.ru API — get key at https://sms.ru)
SMS_RU_API_KEY=your-sms-ru-api-key
# Set to "true" in development to log OTP to console instead of sending SMS
SMS_DEV_MODE=false

# YooKassa (https://yookassa.ru/developers)
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key

# CRM Webhook URL (leave empty to disable CRM integration)
CRM_WEBHOOK_URL=https://your-crm.example.com/webhooks/orders
CRM_WEBHOOK_SECRET=your-crm-webhook-secret
